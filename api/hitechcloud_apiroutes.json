            "name": "Get Account Details",
            "description": "Get hosting account details for a service",
            "param": [],
            "route": "GET /service/@id/account",
            "auth": true,
            "handle": "account_get",
            "category": "Services",
            "http": "GET",
            "address": "/service/@id/account"
        },
