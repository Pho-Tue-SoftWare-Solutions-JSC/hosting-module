            "category": "Services",
            "http": "GET",
            "address": "/service/@id/domains"
        },
        "POST /service/@id/domains": {
            "name": "Add Domain",
            "description": "Add a domain to the hosting account",
            "param": [
                {"type": "string", "name": "domain", "description": "Domain name", "example": "example.com"},
                {"type": "string", "name": "type", "description": "Domain type (addon, subdomain)", "example": "addon"}
